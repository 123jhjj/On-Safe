<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/widget_config_bg">

    <!-- 상태바 + AppBar 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        android:background="@color/widget_config_header_bg">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="bottom|start"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_config_title"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/widget_config_header_title"
                android:letterSpacing="-0.02"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/widget_config_divider" />

    <!-- 컨텐츠 영역 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_config_card"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/widget_config_contact_section"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/widget_config_text_secondary"
                android:letterSpacing="0.06"
                android:textAllCaps="true"
                android:includeFontPadding="false" />

            <LinearLayout
                android:id="@+id/contact_selector"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_contact_field"
                android:paddingStart="16dp"
                android:paddingEnd="14dp"
                android:clickable="true"
                android:focusable="true">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_contact_role"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="SKO 관리감독자"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="@color/widget_config_text_primary"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                    <TextView
                        android:id="@+id/tv_contact_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="@string/widget_config_unregistered"
                        android:textSize="13sp"
                        android:textColor="@color/widget_config_text_tertiary"
                        android:maxLines="1"
                        android:ellipsize="end"
                        android:includeFontPadding="false" />

                </LinearLayout>

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_chevron_down"
                    android:contentDescription="@null"
                    android:importantForAccessibility="no" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/section_alpha"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="vertical"
            android:background="@drawable/bg_config_card"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/widget_config_alpha_section"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_config_text_secondary"
                    android:letterSpacing="0.06"
                    android:textAllCaps="true"
                    android:includeFontPadding="false" />

                <TextView
                    android:id="@+id/tv_transparency_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="13%"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/widget_config_accent_dark"
                    android:includeFontPadding="false" />

            </LinearLayout>

            <SeekBar
                android:id="@+id/seek_transparency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:max="100"
                android:progress="13"
                android:progressTint="@color/widget_config_accent"
                android:thumbTint="@color/widget_config_accent_dark" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0%"
                    android:textSize="11sp"
                    android:textColor="@color/widget_config_text_tertiary"
                    android:includeFontPadding="false" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textSize="11sp"
                    android:textColor="@color/widget_config_text_tertiary"
                    android:includeFontPadding="false" />

            </LinearLayout>

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="@string/widget_config_cancel"
                android:textSize="15sp"
                android:textColor="@color/widget_config_text_secondary"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_secondary"
                android:stateListAnimator="@null" />

            <View
                android:layout_width="10dp"
                android:layout_height="match_parent" />

            <Button
                android:id="@+id/btn_confirm"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="2"
                android:text="@string/widget_config_confirm"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/widget_config_btn_primary_text"
                android:textAllCaps="false"
                android:background="@drawable/bg_btn_primary"
                android:stateListAnimator="@null" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
