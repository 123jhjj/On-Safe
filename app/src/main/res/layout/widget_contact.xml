<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="8dp"
    android:paddingEnd="8dp"
    android:paddingTop="6dp"
    android:paddingBottom="6dp"
    android:background="#FFFFFF">

    <LinearLayout
        android:id="@+id/contact1_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center">

        <ImageView
            android:id="@+id/contact1_call_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_phone_in_talk_rounded"
            android:tint="#185FA5"
            android:scaleType="fitCenter"
            android:contentDescription="전화" />

        <TextView
            android:id="@+id/contact1_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="SKO 관리감독자"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#1A1A2E"
            android:gravity="center"
            android:textAlignment="center"
            android:maxLines="2"
            android:ellipsize="end"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/contact1_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textSize="12sp"
            android:textColor="#5A5A7A"
            android:gravity="center"
            android:textAlignment="center"
            android:maxLines="1"
            android:ellipsize="end"
            android:includeFontPadding="false"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>
