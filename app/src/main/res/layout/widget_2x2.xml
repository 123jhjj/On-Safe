<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="10dp"
    android:background="#FFFFFFFF">

    <TextView
        android:id="@+id/tv_app_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="On-Safe"
        android:textSize="14dp"
        android:textStyle="bold"
        android:textColor="#FFBA7517"
        android:gravity="center"
        android:maxLines="1"
        android:includeFontPadding="false" />

    <LinearLayout
        android:id="@+id/contact1_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingTop="8dp"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/contact1_role"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SKO 관리감독자"
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="#FF888780"
            android:maxLines="1"
            android:ellipsize="end"
            android:gravity="center"
            android:includeFontPadding="false" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/contact1_call_icon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="6dp"
                android:src="@drawable/ic_phone_in_talk_rounded"
                android:tint="#FFBA7517"
                android:contentDescription="전화"
                android:scaleType="fitCenter" />

            <TextView
                android:id="@+id/contact1_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="72dp"
                android:text="미등록"
                android:textSize="20dp"
                android:textStyle="bold"
                android:textColor="#FF1A1A1A"
                android:maxLines="1"
                android:ellipsize="end"
                android:gravity="center"
                android:includeFontPadding="false" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
